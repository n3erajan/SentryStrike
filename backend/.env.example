# SentryStrike backend environment template
# Shared database, Redis, queue, lifecycle, and public-host values live in ../.env.

# App
APP_NAME=Sentry Strike Backend
APP_DEBUG=true
CORS_ORIGINS=["*"]

# Backend authentication
AUTH_SESSION_TTL_HOURS=24
AUTH_COOKIE_NAME=sentrystrike_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# Workspace invitations
INVITE_TTL_HOURS=168
INVITE_WORKSPACE_LIMIT_PER_HOUR=20
INVITE_ACTOR_LIMIT_PER_TEN_MINUTES=5
INVITE_RATE_LIMIT_KEY_PREFIX=sentrystrike:invite-rate

# SMTP email delivery
# Gmail requires 2-Step Verification plus an app password.
EMAIL_FROM=SentryStrike <no-reply@sentrystrike.local>
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_STARTTLS=true

# Scan-data retention worker
RETENTION_PURGE_INTERVAL_SECONDS=43200

# Backend logging is console-only.
LOG_LEVEL=INFO
