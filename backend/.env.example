# Sentry Strike backend environment template

# App
APP_NAME=Sentry Strike Backend
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=["*"]

# Database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=sentrystrike

# Scan queue
REDIS_URL=redis://localhost:6379/0
SCAN_QUEUE_NAME=sentrystrike:scans
SCAN_CANCEL_KEY_PREFIX=sentrystrike:scan:cancel
SCAN_CANCEL_TTL_SECONDS=86400
OAST_INTERACTION_TTL_SECONDS=3600
# Worker liveness heartbeat (drives the /health active-scanner count)
WORKER_HEARTBEAT_PREFIX=sentrystrike:worker:heartbeat
WORKER_HEARTBEAT_TTL_SECONDS=20
# Per-scan lease: a running worker renews this key on a timer; if it expires
# (worker crashed) the scan is reconciled to "failed" at read time.
SCAN_LEASE_KEY_PREFIX=sentrystrike:scan:lease
SCAN_LEASE_TTL_SECONDS=30

# Backend authentication
AUTH_SESSION_TTL_HOURS=24
AUTH_COOKIE_NAME=sentrystrike_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# Workspace invitations
INVITE_TTL_HOURS=168
INVITE_WORKSPACE_LIMIT_PER_HOUR=20
INVITE_ACTOR_LIMIT_PER_TEN_MINUTES=5
INVITE_RATE_LIMIT_KEY_PREFIX=sentrystrike:invite-rate

# SMTP email delivery.
# Gmail requires 2-Step Verification plus an app password (not the account password).
EMAIL_FROM=SentryStrike <no-reply@sentrystrike.local>
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_STARTTLS=true

# Logging (console only; omit LOG_FILE — scanner owns the file log)
LOG_LEVEL=INFO
