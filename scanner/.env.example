# SentryStrike scanner worker environment template
# Shared database, Redis, queue, lifecycle, and public-host values live in ../.env.

# Analysis handoff repair cadence
ANALYSIS_RECONCILE_INTERVAL_SECONDS=30

# Crawler / scanner
CRAWL_DEPTH=3
CRAWL_MAX_URLS=200
CRAWL_RATE_LIMIT_PER_SECOND=8.0
CRAWL_BROWSER_MODE=auto
CRAWL_BROWSER_MAX_INTERACTIONS=25
CRAWL_BROWSER_BUDGET_SECONDS=300.0
REQUEST_TIMEOUT_SECONDS=10.0
SCANNER_CONCURRENCY=8
SCAN_MODE=verified
BLIND_INJECTION_TIMING_THRESHOLD=0.7

# Authenticated scanning credentials are supplied per scan, never by environment.
ALLOW_SECONDARY_PROVISIONING=false

# OAST callback/poll URLs normally derive from PUBLIC_HOSTNAME in ../.env.
# Set these only for split topologies where callback and poll routes differ.
# OAST_CALLBACK_BASE_URL=http://host.docker.internal:8000/oast
# OAST_POLL_URL=http://localhost:8000/oast/poll
SSRF_INBAND_TIMING_DELTA_MS=1500.0

# CVE / NVD integration
NVD_API_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
NVD_API_KEY=
CVE_CACHE_TTL_SECONDS=3600

# Scanner logging
LOG_LEVEL=INFO
LOG_FILE=logs/scanner.log
