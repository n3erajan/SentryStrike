# Sentry Strike scanner worker environment template

# Database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=sentrystrike

# Scan queue
REDIS_URL=redis://localhost:6379/0
SCAN_QUEUE_NAME=sentrystrike:scans
SCAN_CANCEL_KEY_PREFIX=sentrystrike:scan:cancel
SCAN_CANCEL_TTL_SECONDS=86400
OAST_INTERACTION_TTL_SECONDS=3600

# AI / LLM - OpenAI-compatible Chat Completions API
AI_BASE_URL=http://localhost:11434/v1
AI_MODEL=gemma4-e4b-8k
AI_API_KEY=
AI_TIMEOUT_SECONDS=120.0
AI_MAX_RETRIES=3
AI_BATCH_SIZE=1
AI_JSON_MODE=true
AI_REASONING_EFFORT=none
AI_ANALYSIS_ENABLED=true

# Crawler / scanner
CRAWL_DEPTH=3
CRAWL_MAX_URLS=200
CRAWL_RATE_LIMIT_PER_SECOND=8.0
CRAWL_BROWSER_MODE=auto
CRAWL_BROWSER_MAX_INTERACTIONS=25
CRAWL_BROWSER_BUDGET_SECONDS=300.0
REQUEST_TIMEOUT_SECONDS=10.0
SCANNER_CONCURRENCY=8
SCAN_MODE=verified
BLIND_INJECTION_TIMING_THRESHOLD=0.7

# Authenticated scanning credentials are supplied per-scan with the scan
# request (never from the environment), so there are no SCAN_AUTH_* vars here.
ALLOW_SECONDARY_PROVISIONING=false

# Out-of-band verification
# Simplest setup: set OAST_HOSTNAME to your backend's host (or full base URL) and
# both OAST URLs are derived from it (<base>/oast for callbacks, <base>/oast/poll
# for polling). A bare host gets https:// unless it's localhost/127.0.0.1.
# Examples: OAST_HOSTNAME=sentry.example.com  or  OAST_HOSTNAME=https://sentry.example.com
OAST_HOSTNAME=
# Advanced/split topology only: override either derived URL. Needed when the
# callback must resolve from the target container while polling reaches the host
# backend directly (host-run worker + Dockerized target). docker-compose.yml
# supplies container-specific defaults for its scanner service. When set, each
# takes precedence over the value derived from OAST_HOSTNAME.
OAST_CALLBACK_BASE_URL=
OAST_POLL_URL=
SSRF_INBAND_TIMING_DELTA_MS=1500.0

# CVE / NVD integration
NVD_API_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
NVD_API_KEY=
CVE_CACHE_TTL_SECONDS=3600

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/scanner.log
