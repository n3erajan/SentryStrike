# SentryStrike deployment-wide environment template
#
# Copy this file to .env at the repository root. These values coordinate two
# or more services; service-specific values belong in each service's .env.

# Shared data stores
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=sentrystrike
REDIS_URL=redis://localhost:6379/0

# Scan queue and scanner lifecycle signals (backend + scanner)
SCAN_QUEUE_NAME=sentrystrike:scans
SCAN_CANCEL_KEY_PREFIX=sentrystrike:scan:cancel
SCAN_CANCEL_TTL_SECONDS=86400
SCAN_LEASE_KEY_PREFIX=sentrystrike:scan:lease
SCAN_LEASE_TTL_SECONDS=30
WORKER_HEARTBEAT_PREFIX=sentrystrike:worker:heartbeat
WORKER_HEARTBEAT_TTL_SECONDS=20

# Durable analysis wake-up queue (backend + scanner + analyzer)
ANALYSIS_QUEUE_NAME=sentrystrike:analysis

# Shared database model behavior
OAST_INTERACTION_TTL_SECONDS=3600

# Public hostname or full base URL (backend invite links + scanner OAST URLs)
# Examples: sentry.example.com or https://sentry.example.com
PUBLIC_HOSTNAME=

# Docker Compose / frontend build overrides
FRONTEND_PORT=80
BACKEND_PORT=8000
VITE_API_URL=/api/v1
