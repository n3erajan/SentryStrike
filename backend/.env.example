# Sentry Strike backend environment template

# App
APP_NAME=Sentry Strike Backend
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=["*"]

# Database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=sentrystrike

# Backend authentication
ALLOW_REGISTRATION=false
AUTH_SESSION_TTL_HOURS=24
AUTH_COOKIE_NAME=sentrystrike_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# AI / Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4-e4b-8k
OLLAMA_TIMEOUT_SECONDS=120.0
AI_MAX_RETRIES=3
AI_BATCH_SIZE=1

# Crawler / scanner
CRAWL_DEPTH=3
CRAWL_MAX_URLS=200
CRAWL_RATE_LIMIT_PER_SECOND=8.0
CRAWL_BROWSER_ENABLED=false
# Dynamic (browser) discovery mode: auto = run only for SPA targets,
# always = run for every target, never = static-only. CRAWL_BROWSER_ENABLED=true
# forces "always" (legacy). Every browser op is time-bounded; partial results
# always survive truncation.
CRAWL_BROWSER_MODE=auto
CRAWL_BROWSER_MAX_INTERACTIONS=25
CRAWL_BROWSER_BUDGET_SECONDS=300.0
REQUEST_TIMEOUT_SECONDS=10.0
SCANNER_CONCURRENCY=8
SCAN_MODE=verified
MAX_VERIFICATION_REQUESTS=10
BLIND_INJECTION_TIMING_THRESHOLD=0.7

# Optional authenticated scanning
SCAN_AUTH_USERNAME=
SCAN_AUTH_PASSWORD=
SCAN_AUTH_COOKIE=
# Auto-register a throwaway second identity for differential IDOR/BOLA when no
# second account is supplied. Off by default (creates a user on the target).
ALLOW_SECONDARY_PROVISIONING=false

# Out-of-band (OAST) callback for verified blind SSRF. When unset, SSRF falls
# back to an in-band internal-vs-external differential that yields probable
# (unverified) findings only. Set both to confirm blind SSRF out-of-band.
OAST_CALLBACK_BASE_URL=
OAST_POLL_URL=
# Min consistent response-time delta (ms) between an internal target and the
# external control before the in-band fallback reports a probable SSRF.
SSRF_INBAND_TIMING_DELTA_MS=1500.0

# CVE / NVD integration
NVD_API_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
NVD_API_KEY=
CVE_CACHE_TTL_SECONDS=3600

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
