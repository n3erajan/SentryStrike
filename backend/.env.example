# Sentry Strike backend environment template

# App
APP_NAME=Sentry Strike Backend
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=["*"]

# Database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=sentrystrike

# Backend authentication
ALLOW_REGISTRATION=false
AUTH_SESSION_TTL_HOURS=24
AUTH_COOKIE_NAME=sentrystrike_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# AI / LLM — single OpenAI-compatible client.
# Works with any Chat Completions API: local Ollama (default, no key needed),
# OpenAI, Groq, Together, OpenRouter, DeepSeek, Mistral, vLLM, LM Studio, ...
# Point AI_BASE_URL at the provider's /v1 root and set AI_MODEL (+ AI_API_KEY
# for hosted providers). To switch providers, change only these three values.
AI_BASE_URL=http://localhost:11434/v1
AI_MODEL=gemma4-e4b-8k
# API key — leave empty for local Ollama / unauthenticated local servers.
AI_API_KEY=
AI_TIMEOUT_SECONDS=120.0
AI_MAX_RETRIES=3
AI_BATCH_SIZE=1
# Send response_format={"type":"json_object"} (OpenAI JSON mode). Disable if
# your provider rejects it — the client still extracts JSON from plain text.
AI_JSON_MODE=true
# Reasoning/thinking control for reasoning-capable models. On Ollama's /v1
# endpoint, "none" disables the model's <think> block (big latency win);
# "low"/"medium"/"high" enable it. Leave empty to keep the provider default.
# Must be a string — the native `think` boolean does not work on /v1.
AI_REASONING_EFFORT=none
# Master switch for AI/LLM analysis. When false, the scanner and report
# generator skip all LLM calls and populate findings with deterministic
# fallbacks (faster, no model needed). Useful for CI/tests or offline runs.
AI_ANALYSIS_ENABLED=true

# Crawler / scanner
CRAWL_DEPTH=3
CRAWL_MAX_URLS=200
CRAWL_RATE_LIMIT_PER_SECOND=8.0
CRAWL_BROWSER_ENABLED=false
# Dynamic (browser) discovery mode: auto = run only for SPA targets,
# always = run for every target, never = static-only. CRAWL_BROWSER_ENABLED=true
# forces "always" (legacy). Every browser op is time-bounded; partial results
# always survive truncation.
CRAWL_BROWSER_MODE=auto
CRAWL_BROWSER_MAX_INTERACTIONS=25
CRAWL_BROWSER_BUDGET_SECONDS=300.0
REQUEST_TIMEOUT_SECONDS=10.0
SCANNER_CONCURRENCY=8
SCAN_MODE=verified
MAX_VERIFICATION_REQUESTS=10
BLIND_INJECTION_TIMING_THRESHOLD=0.7

# Optional authenticated scanning
SCAN_AUTH_USERNAME=
SCAN_AUTH_PASSWORD=
SCAN_AUTH_COOKIE=
# Auto-register a throwaway second identity for differential IDOR/BOLA when no
# second account is supplied. Off by default (creates a user on the target).
ALLOW_SECONDARY_PROVISIONING=false

# Out-of-band (OAST) callback for verified blind SSRF. When unset, SSRF falls
# back to an in-band internal-vs-external differential that yields probable
# (unverified) findings only. Set both to confirm blind SSRF out-of-band.
OAST_CALLBACK_BASE_URL=
OAST_POLL_URL=
# Min consistent response-time delta (ms) between an internal target and the
# external control before the in-band fallback reports a probable SSRF.
SSRF_INBAND_TIMING_DELTA_MS=1500.0

# CVE / NVD integration
NVD_API_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
NVD_API_KEY=
CVE_CACHE_TTL_SECONDS=3600

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
