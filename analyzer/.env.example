# Shared database, Redis, and analysis queue values live in ../.env.
# false skips provider calls and publishes deterministic fallback analysis so
# the revision still completes and PDF readiness is preserved.
AI_ANALYSIS_ENABLED=true
# Compose maps this host name to the Docker host for a local provider. Replace
# it with the provider URL reachable from the analyzer container in production.
AI_BASE_URL=http://host.docker.internal:11434/v1
AI_MODEL=gemma4-e4b-8k
AI_API_KEY=
AI_TIMEOUT_SECONDS=120
AI_MAX_RETRIES=3
AI_JSON_MODE=true
AI_REASONING_EFFORT=none
ANALYSIS_LEASE_SECONDS=300
ANALYSIS_LEASE_RENEW_SECONDS=60
ANALYSIS_POLL_SECONDS=5
ANALYSIS_RECONCILE_INTERVAL_SECONDS=30
ANALYSIS_FINDING_EVIDENCE_MAX_CHARS=6000
ANALYSIS_REPORT_INPUT_MAX_CHARS=24000
LOG_LEVEL=INFO
